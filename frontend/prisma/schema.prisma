generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  projects  Project[]
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  rawPrompt   String?
  nodesJson   String
  edgesJson   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
